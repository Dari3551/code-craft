# ═══════════════════════════════════════════════════════════
#   CodeCraft Systems — WhatsApp Bot — Environment Variables
# ═══════════════════════════════════════════════════════════

# ─────────────────────────────────────────────
# 🔑 OpenAI API Key (مطلوب)
# احصل عليه من: https://platform.openai.com/api-keys
# ─────────────────────────────────────────────
OPENAI_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────
# 📞 رقم خدمة العملاء (اختياري)
# الصيغة: رمز الدولة + الرقم بدون + أو 00
# مثال: 966501234567
# ─────────────────────────────────────────────
SUPPORT_NUMBER=966500000000

# ─────────────────────────────────────────────
# 🌐 منفذ السيرفر (تلقائي في Render)
# ─────────────────────────────────────────────
PORT=3000

# ─────────────────────────────────────────────
# 🔧 مسار Chrome/Chromium (للنشر على Render)
# Render يضعه تلقائيًا — لا تغيره إلا إذا احتجت
# ─────────────────────────────────────────────
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
# CHROME_BIN=/usr/bin/chromium-browser

# ─────────────────────────────────────────────
# 📝 ملاحظات مهمة:
# 1. لا ترفع هذا الملف على GitHub أبدًا!
# 2. أضفه في .gitignore
# 3. في Render: أضف المتغيرات في Environment Variables
# ─────────────────────────────────────────────
